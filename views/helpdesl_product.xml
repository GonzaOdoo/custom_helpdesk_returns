<odoo>
    <record id="view_helpdesk_ticket_form_inherit_components" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.inherit.components</field>
        <field name="model">helpdesk.ticket</field>
        <field name="priority">999</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='active']" position="after">
                <field name="ticket_ref" string="Ticket ID"/>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="attributes">
                <attribute name="domain">[('related_ticket', '=', ticket_type_id)]</attribute>
            </xpath>
             <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="defect_type" string="Sector afectado"/>
                <field name="sector_in_charge"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="partner_email" force_save="1" readonly="True" invisible="0"/>
            </xpath>
            <field name="email_cc" position="after">
                <field name="quality_check_summary" invisible="1"/>
                <field name="quality_check_count" invisible="1"/>
                <field name="product_id" string="Producto" domain="[&quot;&amp;&quot;, (&quot;sale_ok&quot;, &quot;=&quot;, True), (&quot;active&quot;, &quot;in&quot;, [True, False])]"/>
                <field name="component_line_ids" nolabel="1" colspan="2">
                    <list editable="bottom">
                        <field name="helpdesk_ticket_id" column_invisible="True"/>
                        <field name="suitable_component_ids" column_invisible="True"/>
                        <field name="product_id" string="Componente"/>
                        <field name="description"/>
                        <field name="cost"/>
                        <field name="quantity"/>
                    </list>
                </field>
                <field name="component_cost" string="Costo total"/>
                <field name="component_total_value" string="Valor total"/>
            </field>
        </field>
    </record>
</odoo>